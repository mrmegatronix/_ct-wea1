# Set the default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files to be normalized to LF in the repo
# and converted to native line endings on checkout.
*.html  text
*.css   text
*.js    text
*.json  text
*.md    text
*.csv   text

# Denote all files that are truly binary and should not be modified.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary